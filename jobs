                <div class="section-body">
                    <div class="line-items" id="additionalLaborList"></div>
                    <div class="line-item-total">
                        <span>Total Additional Labor</span>
                        <span class="value" id="totalAdditionalLabor">$0</span>
                    </div>
                </div>
