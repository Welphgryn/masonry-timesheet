        <!-- Summary Tab -->
        <div class="tab-content active" id="summaryTab">
            <div class="summary-section">
                <div class="summary-breakdown">
                    <h3 style="color: var(--accent); margin-bottom: 16px;">Cost Breakdown</h3>
